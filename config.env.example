# Copy this file to config.env and customize values for your VPS.

# SSH hardening
SSH_PORT=2222
# Keep the currently active SSH port open during migration to avoid lockouts.
# Set to false only after you verified login works on SSH_PORT.
SSH_KEEP_CURRENT_PORT=true
# Optional manual override for currently active SSH port when auto-detection is not possible.
SSH_CURRENT_PORT_OVERRIDE=
# Enable PAM Google Authenticator integration (uses "nullok" for safe rollout).
ENABLE_SSH_MFA=false

# WireGuard
WG_INTERFACE=wg0
WG_VPS_IP=10.50.0.2/24
WG_HOME_ENDPOINT=home.example.com:51820
WG_HOME_PUBKEY=replace-with-home-server-public-key
# Optional: leave empty to auto-generate on VPS and persist to WG_VPS_PRIVKEY_FILE.
WG_VPS_PRIVKEY=
WG_AUTO_GENERATE_VPS_KEY=true
WG_VPS_PRIVKEY_FILE=/etc/wireguard/wg0.privatekey
# Optional, leave empty if unused
WG_HOME_PRESHARED_KEY=
WG_ALLOWED_IPS=0.0.0.0/0
WG_PERSISTENT_KEEPALIVE=25
WG_DNS=1.1.1.1
# Keep default unless you have a reason to change it.
WG_FWMARK=51820

# OpenClaw
OPENCLAW_PORT=3000
# Future host bind IP for OpenClaw when you install it manually.
# If empty, scripts use the IP part of WG_VPS_IP.
OPENCLAW_BIND_IP=
OPENCLAW_SETUP_DIR=/opt/openclaw
# The scripts do NOT install OpenClaw. They only prepare the VPS.
OPENCLAW_SETUP_USER=openclaw
CREATE_OPENCLAW_USER=true
INSTALL_NODEJS=true
# OpenClaw docs require Node 22+. Default here targets latest major release line.
NODEJS_MAJOR_VERSION=25
# Optional, only needed if you plan to build/run from source with pnpm.
INSTALL_PNPM=false
